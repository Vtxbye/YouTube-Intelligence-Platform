# Copy and paste this file in yt-app.
# Rename to .env

# API Keys
YT_API_KEY=

# Database URL
POSTGRES_URL=

# Frontend and Backend URL
FRONTEND_URL=
NEXT_PUBLIC_API_URL=

# Firebase Auth (API verification)
# Set to true to require Firebase ID tokens on non-public API routes.
FIREBASE_AUTH_ENABLED=false
# Firebase project ID from Project Settings > General
FIREBASE_PROJECT_ID=
# Firebase Web API key from Project Settings > General > Web API Key
FIREBASE_WEB_API_KEY=
# Optional: additional unauthenticated paths (comma-separated)
# FIREBASE_AUTH_PUBLIC_PATHS=/api/public,/webhook/health
